{
  "name": "AI Monitoring System (Clean Version)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 30
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "name": "⏱ Auto Monitor Trigger (30min)"
    },
    {
      "parameters": {
        "url": "http://YOUR_SERVER_IP/system-check"
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "name": "📡 Fetch Server Health Data"
    },
    {
      "parameters": {
        "jsCode": "// Normalize Hosts\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "name": "🧠 Normalize Data"
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{$json.disk}}",
              "operator": {
                "type": "number",
                "operation": "gt"
              },
              "rightValue": 90
            }
          ]
        }
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "name": "⚠ Detect High Usage"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.your-ai-provider.com/analyze",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_API_KEY"
            }
          ]
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "name": "🤖 AI Analysis"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://hooks.slack.com/services/REDACTED",
        "sendBody": true
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "name": "💬 Send Slack Alert"
    }
  ],
  "connections": {}
}